{
  "name": "better-life-naver",
  "version": "2.11.121",
  "description": "Better Life Naver - 네이버 블로그 자동화 앱으로 더 나은 삶을 만들어가세요. Electron, Node.js, TypeScript, and Puppeteer.",
  "author": "Better Life Team",
  "license": "AGPL-3.0-or-later",
  "main": "dist/main.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:agent": "vitest run --config vitest.agent.config.ts --coverage",
    "test:coverage:content-v3": "vitest run --config vitest.content-quality-v3.config.ts --coverage",
    "verify:release": "node scripts/release-gate.js",
    "build": "node scripts/sync-build-define.mjs && tsc && node scripts/copy-static.mjs",
    "build:safe": "npm run verify:release && node scripts/build.js",
    "start": "npm run build && node scripts/run-electron-dev.mjs",
    "dev": "node scripts/run-electron-dev.mjs",
    "cli": "ts-node src/index.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "harness:tail": "node scripts/harness/flow-tail-harness.cjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "lint:ipc": "node scripts/lint-ipc.mjs",
    "prepack": "npm run verify:release && node scripts/reset-config-for-pack.js",
    "pack": "npm run verify:release && node scripts/reset-config-for-pack.js && electron-builder --dir && node scripts/restore-after-pack.js",
    "dist": "npm run verify:release && node scripts/reset-config-for-pack.js && electron-builder && node scripts/restore-after-pack.js && node scripts/create-archives.js",
    "restore": "node scripts/restore-after-pack.js",
    "dist:win": "npm run verify:release && node scripts/reset-config-for-pack.js && electron-builder --win && node scripts/restore-after-pack.js && node scripts/create-archives.js",
    "dist:portable": "npm run verify:release && node scripts/reset-config-for-pack.js && electron-builder --win portable && node scripts/restore-after-pack.js",
    "dist:all": "npm run verify:release && node scripts/reset-config-for-pack.js && electron-builder --win --x64 && node scripts/restore-after-pack.js && node scripts/create-archives.js",
    "dist:mac": "npm run verify:release && node scripts/build-mac.js --arch both",
    "dist:mac:arm64": "npm run verify:release && node scripts/build-mac.js --arch arm64",
    "dist:mac:x64": "npm run verify:release && node scripts/build-mac.js --arch x64",
    "dist:mac:universal": "npm run verify:release && node scripts/build-mac.js --arch universal",
    "dist:mac:unsigned": "npm run verify:release && node scripts/build-mac.js --arch both --unsigned",
    "dist:mac:arm64:unsigned": "npm run verify:release && node scripts/build-mac.js --arch arm64 --unsigned",
    "dist:mac:universal:unsigned": "npm run verify:release && node scripts/build-mac.js --arch universal --unsigned",
    "dist:universal": "npm run verify:release && node scripts/build-mac.js --arch universal",
    "release:mac": "npm run verify:release && node scripts/build-mac.js --arch both --publish",
    "release:mac:unsigned": "npm run verify:release && node scripts/build-mac.js --arch both --unsigned",
    "self-test": "npm run build && node scripts/self-test.mjs",
    "self-test:built": "node scripts/self-test.mjs",
    "start:daily": "npm run build && node dist/scheduler/daily.js",
    "start:monitor": "npm run build && node dist/monitor/realtime.js",
    "start:learning": "npm run build && node dist/learning/analyzer.js",
    "test:generate": "ts-node src/tests/automationSmoke.ts",
    "test:integration": "npm run build && node dist/tests/integrationTest.js",
    "test:draft": "ts-node src/tests/testDraftPublish.ts",
    "test:publish": "echo \"Publish test not implemented\"",
    "test:images": "npm run build && node dist/tests/imageSmoke.js",
    "test:image:insert": "ts-node src/tests/testImageInsert.ts",
    "test:typing:pexels": "npm run build && node dist/tests/typingWithPexels.js",
    "test:typing": "tsx test-typing-automation.ts",
    "test:gemini": "ts-node test-gemini-json.ts",
    "test:full": "ts-node test-full-generation.ts",
    "test:content-engines": "node scripts/test-content-engines.mjs",
    "test:content-engines:app": "npm run build && electron scripts/test-content-engine-smoke.cjs all",
    "test:image-providers": "npm run build && electron scripts/test-image-provider-smoke.cjs all",
    "diagnose:openai": "node scripts/diagnose-openai-access.mjs",
    "test:login": "npm run build && node dist/tests/testLogin.js",
    "test:full-flow": "npm run build && node dist/tests/testFullFlow.js",
    "test:image-model-settings": "ts-node src/tests/testImageModelSettings.ts",
    "test:schedule-calendar": "ts-node src/tests/testScheduleCalendar.ts",
    "e2e": "npm run build && playwright test",
    "e2e:built": "playwright test",
    "e2e:ui": "playwright test --ui",
    "dist:setup": "npm run verify:release && node scripts/reset-config-for-pack.js && electron-builder --win nsis && node scripts/restore-after-pack.js",
    "release": "npm run verify:release && node scripts/reset-config-for-pack.js && electron-builder --win nsis && node scripts/restore-after-pack.js",
    "release:full": "node scripts/release-all.js",
    "packaged-smoke": "node scripts/packaged-app-smoke.mjs",
    "probe:serp": "node scripts/probe-serp.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.21.1",
    "@google/generative-ai": "^0.24.1",
    "@imgly/background-removal": "^1.7.0",
    "@rohitaryal/imagefx-api": "^3.0.3",
    "@types/xlsx": "^0.0.35",
    "app-builder-bin": "^5.0.0-alpha.12",
    "axios": "^1.6.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.7.3",
    "ffmpeg-static": "^5.2.0",
    "figlet": "^1.9.4",
    "ghost-cursor": "^1.4.2",
    "ghost-cursor-playwright": "^2.1.0",
    "got-scraping": "^4.1.3",
    "gradient-string": "^3.0.0",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "openai": "^4.104.0",
    "ora": "^9.0.0",
    "patchright": "^1.60.0",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.43.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "redis": "^4.6.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "ulid": "^3.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.4",
    "cross-env": "^10.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.10.2",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "happy-dom": "^20.9.0",
    "rcedit": "^5.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.betterlife.naver",
    "productName": "Better Life Naver",
    "directories": {
      "output": "release_final"
    },
    "files": [
      "dist/**/*",
      "!dist/settings.json",
      "!dist/**/*.tmp.js",
      "!dist/renderer/_original_*.js",
      "!dist/**/*.map",
      "LICENSE",
      "COMMERCIAL-LICENSING.md",
      "TRADEMARKS.md",
      "THIRD_PARTY_NOTICES.md",
      "docs/LICENSING.md",
      "docs/FFMPEG_COMPLIANCE.md",
      "docs/content-quality-v3/legacy-baseline.json",
      "package.json",
      "node_modules/**/*",
      "!node_modules/**/*.map",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**"
    ],
    "asarUnpack": [
      "node_modules/puppeteer/**/*",
      "node_modules/puppeteer-extra/**/*",
      "node_modules/playwright/**/*",
      "node_modules/playwright-core/**/*",
      "node_modules/playwright-extra/**/*",
      "node_modules/patchright/**/*",
      "node_modules/patchright-core/**/*",
      "node_modules/ffmpeg-static/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/@imgly/**/*",
      "node_modules/.bin/**/*",
      "dist/prompts/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "artifactName": "Better-Life-Naver-${version}-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "singleArchFiles": "**/node_modules/@img/*darwin*/**/*",
      "x64ArchFiles": "**/node_modules/@img/*darwin*/**/*",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSDownloadsFolderUsageDescription": "Better Life Naver saves generated and collected blog images to Downloads.",
        "NSDocumentsFolderUsageDescription": "Better Life Naver may open or save user-selected automation files."
      }
    },
    "dmg": {
      "title": "Better Life Naver ${version}",
      "artifactName": "Better-Life-Naver-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "Better-Life-Naver-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Better Life Naver",
      "perMachine": false,
      "allowElevation": true,
      "include": "build/installer.nsh"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist/prompts",
        "to": "prompts",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "app-update.yml",
        "to": "app-update.yml"
      }
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "cd000242-sudo",
      "repo": "naver",
      "releaseType": "release"
    }
  }
}
