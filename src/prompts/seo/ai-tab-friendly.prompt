━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

□ 본문 6,000~8,000자 범위 (자료 부족 시 (자료 부족) 명시 후 자르기 — 일반론 채우기 금지)
□ 소제목 2~7개 (질문형 3~4개 포함)
