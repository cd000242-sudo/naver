{
  "mcpServers": {
    "context7": {
      "$comment": "Up-to-date documentation and code examples via Context7",
      "args": [
        "-l",
        "-c",
        "exec npx -y @upstash/context7-mcp@latest"
      ],
      "command": "/bin/bash"
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp"
    },
    "github": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-github@2025.4.8"
      ],
      "command": "npx"
    },
    "memory": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory@2026.1.26"
      ],
      "command": "npx"
    },
    "playwright": {
      "args": [
        "-y",
        "@playwright/mcp@0.0.69",
        "--isolated"
      ],
      "command": "npx"
    },
    "sequential-thinking": {
      "$comment": "Step-by-step reasoning for complex problems (--think flag)",
      "args": [
        "-l",
        "-c",
        "exec npx -y @modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "/bin/bash"
    }
  }
}
