{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "auto react check --quiet",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "auto check --arch --quiet --warn-only",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(./node_modules/electron/dist/electron.exe -e \"process.stdout.write\\(JSON.stringify\\(process.versions\\)\\)\")",
      "Bash(auto *)",
      "Bash(auto:*)",
      "Bash(git *)",
      "Bash(git:*)",
      "Bash(make:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(gh:*)",
      "mcp__sequential-thinking__sequentialthinking",
      "WebSearch",
      "Agent",
      "AskUserQuestion",
      "TaskCreate",
      "TaskUpdate",
      "TeamCreate",
      "SendMessage",
      "ToolSearch",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(pnpm *)",
      "Bash(yarn *)"
    ]
  },
  "statusLine": {
    "command": ".claude/statusline.sh",
    "padding": 1,
    "type": "command"
  }
}
